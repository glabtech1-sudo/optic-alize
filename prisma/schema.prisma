datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  currency  String   @default("XOF")
  taxRate   Float    @default(18.0)
  symbol    String   @default("FCFA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]

  @@map("companies")
}

model Branch {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  zoneId      String       @default("zone-1")
  code        String       @unique
  name        String
  address     String
  city        String       @default("Boutique")
  phone       String
  email       String
  logo        String?
  managerId   String       @default("manager-1")
  currency    String       @default("XOF")
  language    String       @default("FR")
  taxRate     Float        @default(18.0)
  status      String       @default("Actif") // Actif, Fermé, Audit, Inactif, Archivé
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userBranches UserBranch[]
  customers   Customer[]
  inventories Inventory[]
  invoices    Invoice[]

  @@map("branches")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id             String       @id @default(uuid())
  companyId      String       @default("TG")
  name           String
  email          String       @unique
  password       String?
  mfaEnabled     Boolean      @default(false)
  mfaSecret      String?
  phone          String       @default("")
  location       String       @default("")
  lastActive     String       @default("")
  status         String       @default("Active") // Active, Suspended, Pending MFA, Invited
  roleId         String?
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  allowedModules String[]     @default([])
  userBranches   UserBranch[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}

model UserBranch {
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model Customer {
  id               String    @id @default(uuid())
  companyId        String    @default("TG")
  firstName        String
  lastName         String
  birthDate        String
  email            String    @default("")
  phone            String    @default("")
  ssn              String    @default("")
  registrationDate String
  loyaltyTier      String    @default("STANDARD") // STANDARD, GOLD, PLATINUM, VIP
  loyaltyPoints    Int       @default(0)
  branchId         String?
  branch           Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  invoices         Invoice[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("customers")
}

model Supplier {
  id          String    @id @default(uuid())
  companyId   String    @default("TG")
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("suppliers")
}

model Product {
  id          String      @id @default(uuid())
  companyId   String      @default("TG")
  name        String
  brand       String
  category    String
  price       Float
  barcode     String?
  icon        String?     @default("🕶️")
  supplierId  String?
  supplier    Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  inventories Inventory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")
}

model Inventory {
  id        String   @id @default(uuid())
  companyId String   @default("TG")
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0)
  minStock  Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, productId])
  @@map("inventory")
}

model Invoice {
  id            String    @id @default(uuid())
  companyId     String    @default("TG")
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  branchId      String
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date          String
  time          String
  total         Float
  discount      Float     @default(0.0)
  status        String    @default("Paid") // Paid, Pending, PartiallyPaid
  paymentMethod String
  cashier       String
  payments      Payment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("invoices")
}

model Payment {
  id        String   @id @default(uuid())
  companyId String   @default("TG")
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    String
  date      String
  status    String   @default("SUCCESS") // SUCCESS, PENDING, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String   @default("TG")
  userId    String?
  userEmail String
  action    String
  details   String
  timestamp DateTime @default(now())

  @@map("audit_logs")
}
